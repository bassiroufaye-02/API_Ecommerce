<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="create-orders-table" author="ecommerce-api">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="orders"/>
            </not>
        </preConditions>
        <createTable tableName="orders">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_number" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="customer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="store_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="discount_amount" type="DECIMAL(10,2)" defaultValue="0.00">
                <constraints nullable="false"/>
            </column>
            <column name="final_amount" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="ENUM('PENDING', 'CONFIRMED', 'PREPARING', 'SHIPPED', 'DELIVERED', 'CANCELLED')">
                <constraints nullable="false"/>
            </column>
            <column name="shipping_address" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="billing_address" type="TEXT"/>
            <column name="payment_method" type="VARCHAR(50)"/>
            <column name="payment_status" type="ENUM('PENDING', 'PAID', 'FAILED', 'REFUNDED')">
                <constraints nullable="false"/>
            </column>
            <column name="coupon_id" type="BIGINT"/>
            <column name="order_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="orders"
                baseColumnNames="customer_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_orders_customer"
                onDelete="RESTRICT"/>

        <addForeignKeyConstraint
                baseTableName="orders"
                baseColumnNames="store_id"
                referencedTableName="stores"
                referencedColumnNames="id"
                constraintName="fk_orders_store"
                onDelete="RESTRICT"/>

        <addForeignKeyConstraint
                baseTableName="orders"
                baseColumnNames="coupon_id"
                referencedTableName="coupons"
                referencedColumnNames="id"
                constraintName="fk_orders_coupon"
                onDelete="SET NULL"/>

        <createIndex tableName="orders" indexName="idx_orders_customer">
            <column name="customer_id"/>
        </createIndex>

        <createIndex tableName="orders" indexName="idx_orders_store">
            <column name="store_id"/>
        </createIndex>

        <createIndex tableName="orders" indexName="idx_orders_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="orders" indexName="idx_orders_date">
            <column name="order_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
