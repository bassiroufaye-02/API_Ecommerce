<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="create-shopping-cart-table" author="ecommerce-api">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="shopping_carts"/>
            </not>
        </preConditions>
        <createTable tableName="shopping_carts">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="store_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="DECIMAL(10,2)" defaultValue="0.00">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="shopping_carts"
                baseColumnNames="customer_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_shopping_carts_customer"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="shopping_carts"
                baseColumnNames="store_id"
                referencedTableName="stores"
                referencedColumnNames="id"
                constraintName="fk_shopping_carts_store"
                onDelete="CASCADE"/>

        <createIndex tableName="shopping_carts" indexName="idx_shopping_carts_customer">
            <column name="customer_id"/>
        </createIndex>

        <createIndex tableName="shopping_carts" indexName="idx_shopping_carts_store">
            <column name="store_id"/>
        </createIndex>

        <addUniqueConstraint tableName="shopping_carts"
                             columnNames="customer_id,store_id"
                             constraintName="uq_shopping_cart_customer_store"/>
    </changeSet>

</databaseChangeLog>
